{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node scripts/apply-migrations.mjs && next build",
  "crons": [
    {
      "path": "/api/admin/content/auto-package",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/admin/outreach/refresh",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/recover-previews",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/birthday-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/cast-calls",
      "schedule": "*/5 * * * *"
    }
  ]
}
