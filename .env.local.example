# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# --- Anthropic (lyric generation) ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional model override. Default: claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Suno via sunoapi.org (music generation) ---
SUNO_API_KEY=
SUNO_API_BASE_URL=https://api.sunoapi.org
# Suno model version. Common values: V3_5, V4, V4_5. Default: V4
SUNO_MODEL=V4
# Optional. Some sunoapi.org tiers require a callback URL even when polling.
# Leave blank to omit the field from generate requests.
SUNO_CALLBACK_URL=

# --- Vercel Blob (ALL media storage: audio cuts, share video, photos, slideshow) ---
# The app's uploadToR2() helper (lib/r2.ts) now writes to Vercel Blob — no
# Cloudflare/R2 account needed. Set automatically by `vercel env pull` after a
# Blob store is linked to the project.
BLOB_READ_WRITE_TOKEN=

# --- Vercel KV (share metadata) ---
# Set automatically by `vercel env pull` after a KV (Redis) store is linked.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=

# --- OpenAI (Whisper word-timing transcription for premium captions) ---
# Reuses the existing OpenAI key. Optional model override; default whisper-1.
OPENAI_API_KEY=sk-...
# OPENAI_WHISPER_MODEL=whisper-1

# --- Premium Remotion render worker (separate package in ./remotion) ---
# When RENDER_WORKER_URL is set, unlocked songs POST a render job to the worker,
# which renders the MP4 and uploads it to R2. Leave BLANK to keep the built-in
# ffmpeg video as the shown video (no premium render). RENDER_WORKER_SECRET is a
# shared bearer token the app sends and the worker verifies.
RENDER_WORKER_URL=
RENDER_WORKER_SECRET=

# --- Cloudflare R2 (OPTIONAL — only for the separate Remotion render worker) ---
# The Next app no longer uses R2 (it stores media on Vercel Blob above). These
# are ONLY needed if you deploy the standalone ./remotion worker, which still
# uploads its premium MP4s to R2. Leave blank unless/until you deploy it.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ── Consumer login + admin comp ─────────────────────────────────────────────
# Signing key for the passwordless magic-link session (lib/user-session). REQUIRED
# for both the optional "My Songs" login AND the admin comp allowlist below
# (an admin must be logged in so their verified email can be matched). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set the same value in Vercel prod, or generate a distinct one there.
USER_SESSION_SECRET=
# OPTIONAL extra comp (free-unlock) emails, on top of the built-in admin list in
# lib/comp-emails.ts. Comma/space/semicolon separated. Logged-in users whose
# verified email is here unlock the full song (audio+video) without paying.
COMP_EMAILS=

# Launch (intro) discount — integer percent off the base price (e.g. 50).
# Drives both the struck-through paywall price AND the actual Stripe charge (the
# checkout route auto-applies a matching coupon). Empty/0 = off (full price, and
# the promo-code field shows for the ADMINCOMP fallback). NEXT_PUBLIC so client +
# server read the same value; it's build-time inlined, so start/stop = redeploy.
NEXT_PUBLIC_LAUNCH_DISCOUNT_PERCENT=
