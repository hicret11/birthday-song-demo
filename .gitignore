# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# large media not tracked in git
/videos.mp4

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# supabase (transient CLI state — not project source)
supabase/.temp
supabase/.branches

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# Discovery batch outputs (mass-generation videos)
out/

# Local dev-only assets — never ship to production
# public/_test holds sample mp3s that would otherwise be publicly served at /_test/*
public/_test/
# One-off local seed/debug scripts
scripts/dev/

# Privacy exports — contain PII; never commit
privacy-exports/

# Content-automation rendered output + local source clips (media, not source)
content-automation/output/
content-automation/assets/*.mp4
content-automation/assets/*.mov
# AI-generated source clips (media only — keep .gitkeep + metadata .json tracked)
content-automation/assets/ai-generated/**/*.mp4
content-automation/assets/ai-generated/**/*.mov

# Product-output packages (rendered media + may reference recipient data — never commit)
content-automation/product-outputs/
# Real share-ID lists (keep the .example template tracked)
content-automation/share-ids.txt
